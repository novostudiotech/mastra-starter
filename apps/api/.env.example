# ============================================
# App Configuration
# ============================================

# Required
APP_NAME=mastra-starter

# Optional (defaults shown)
# NODE_ENV=development
# APP_ENV=local
# PORT=3000
# LOG_LEVEL=debug
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# PUBLIC_URL=http://localhost:3000

# ============================================
# Database (required)
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mastra_starter

# ============================================
# Redis (required for BullMQ / caching)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# Auth (required)
# ============================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-at-least-32-characters-long!!

# ============================================
# Email — Resend (optional)
# ============================================
# RESEND_API_KEY=re_xxxxxxxxxxxxx
# EMAIL_FROM=noreply@example.com
# EMAIL_REPLY_TO=support@example.com

# ============================================
# AI / LLM (optional, needed for Mastra agents)
# ============================================
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# ============================================
# Sentry (optional)
# ============================================
# SENTRY_DSN=https://xxx@sentry.io/xxx
# SENTRY_ENVIRONMENT=local
