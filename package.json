{
  "name": "mastra-starter",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @mastra-starter/api dev",
    "dev:plugin": "pnpm --filter @mastra-starter/plugin dev",
    "dev:web": "pnpm --filter @mastra-starter/web dev",
    "dev:all": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "build:plugin": "pnpm --filter @mastra-starter/plugin build",
    "studio": "pnpm --filter @mastra-starter/api studio",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
