{
  "name": "mastra-starter",
  "private": true,
  "description": "Modern AI agent starter — Mastra + NestJS 11 + CopilotKit",
  "license": "MIT",
  "keywords": ["mastra", "nestjs", "copilotkit", "ai-agents", "typescript", "better-auth"],
  "scripts": {
    "dev": "pnpm --filter @mastra-starter/api dev",
    "dev:web": "pnpm --filter @mastra-starter/web dev",
    "dev:all": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @mastra-starter/web build",
    "studio": "pnpm --filter @mastra-starter/api studio",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  }
}
